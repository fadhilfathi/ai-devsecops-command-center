{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Service overview for {{service}} — RED + USE + SLOs. Provisioned from infra/observability/grafana/provisioning/dashboards/.",
  "editable": false,
  "graphTooltip": 1,
  "title": "{{service}} — Service Overview",
  "tags": ["observability", "service", "{{service}}"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total{service=~\"$service\"}, route)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "SLO",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Availability (30d rolling)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "avg_over_time(service:auth:availability:ratio5m{service=~\"$service\"}[30d])",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.999 },
              { "color": "green", "value": 0.9995 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Budget Remaining",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "service_error_budget_remaining_ratio{service=~\"$service\"}",
          "legendFormat": "{{service}} — {{slo}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.2 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p99 Latency (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "service:http_request_duration:p99{service=~\"$service\",route=~\"$route\"}",
          "legendFormat": "{{service}} — {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "MTTR (90d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        { "expr": "avg_over_time(incident_time_to_resolve_seconds_sum[90d]) / avg_over_time(incident_time_to_resolve_seconds_count[90d])" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "RED",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request rate (req/s) by status class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(http_requests_total{service=~\"$service\",route=~\"$route\"}[5m]))",
          "legendFormat": "{{status_class}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error rate (5xx ratio)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "service:http_request_errors:ratio5m{service=~\"$service\",route=~\"$route\"}",
          "legendFormat": "{{service}} — {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        { "expr": "service:http_request_duration:p50{service=~\"$service\",route=~\"$route\"}", "legendFormat": "p50 — {{service}} {{route}}" },
        { "expr": "service:http_request_duration:p95{service=~\"$service\",route=~\"$route\"}", "legendFormat": "p95 — {{service}} {{route}}" },
        { "expr": "service:http_request_duration:p99{service=~\"$service\",route=~\"$route\"}", "legendFormat": "p99 — {{service}} {{route}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "USE",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU utilization (vs limit)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 23 },
      "targets": [
        { "expr": "service:cpu:utilization:ratio5m{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory utilization (vs limit)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 23 },
      "targets": [
        { "expr": "service:memory:utilization:ratio5m{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Event loop lag (p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 23 },
      "targets": [
        { "expr": "service:nodejs:eventloop_lag:p99{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 14,
      "type": "row",
      "title": "Dependencies",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": true
    },
    {
      "id": 15,
      "type": "row",
      "title": "Saturation & Capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": true
    }
  ]
}
