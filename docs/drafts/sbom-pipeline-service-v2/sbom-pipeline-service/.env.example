# Service
SBOM_HOST=0.0.0.0
SBOM_PORT=4007
SBOM_LOG_LEVEL=INFO
SBOM_WORKERS=1
SBOM_REQUIRE_AUTH=false

# Syft
SBOM_SYFT_BINARY=syft
SBOM_REQUEST_TIMEOUT_SECONDS=600
SBOM_MAX_CONCURRENT_SCANS=4

# Storage
SBOM_DB_URL=sqlite+aiosqlite:///./backend/data/sbom.db
SBOM_OBJECT_STORE_URL=fs://./backend/data/sbom-store
SBOM_DATA_DIR=./backend/data

# Event bus
SBOM_BUS_URL=memory://
SBOM_BUS_SUBJECT_PREFIX=security.sbom
SBOM_BUS_REQUESTED_SUBJECT=security.sbom.requested.v1

# Signing (production only)
SBOM_COSIGN_ENABLED=false
# SBOM_COSIGN_KEY=/run/secrets/cosign.key

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
