# =============================================================================
# AI-DevSecOps-Command-Center - Environment Configuration Example
# Copy to .env and fill in real values. NEVER commit a real .env file.
# =============================================================================

# ----- General -----
NODE_ENV=development
LOG_LEVEL=info
APP_NAME=ai-devsecops-command-center
APP_VERSION=0.1.0
APP_PORT=3000
APP_URL=http://localhost:3000

# ----- Frontend (AionUi) -----
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws
VITE_APP_NAME=AI-DevSecOps Command Center

# ----- Backend services -----
# Each service runs on its own port; defaults shown
AUTH_SERVICE_PORT=3001
AGENT_SERVICE_PORT=3002
SECURITY_SERVICE_PORT=3003
INCIDENT_SERVICE_PORT=3004
COMPLIANCE_SERVICE_PORT=3005
INTEGRATION_SERVICE_PORT=3006

# ----- Auth / Security -----
JWT_SECRET=change-me-to-a-long-random-string-min-256-bits
JWT_ACCESS_TTL=900            # 15 min
JWT_REFRESH_TTL=2592000       # 30 days
SESSION_SECRET=change-me-too
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=change-me-32-bytes-base64
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ----- Database -----
# Postgres
DATABASE_URL=postgres://aionrs:aionrs@localhost:5432/command_center
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_TLS=false

# ----- Event bus -----
# Either redis-streams or nats
EVENT_BUS_DRIVER=redis-streams
EVENT_BUS_URL=redis://localhost:6379
# NATS_URL=nats://localhost:4222
EVENT_BUS_TLS=false
EVENT_BUS_SUBJECT_PREFIX=devsecops

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-devsecops-command-center
PROMETHEUS_PORT=9090
LOKI_URL=http://localhost:3100
GRAFANA_URL=http://localhost:3001

# ----- GitHub integration -----
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_DEFAULT_BRANCH=main

# ----- AI / Model providers -----
# Used by agents — keep keys out of source control
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AIONRS_BASE_URL=
AIONRS_API_KEY=
AIONRS_DEFAULT_MODEL=MiniMax-M3

# ----- Rate limits -----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ----- Feature flags -----
FEATURE_GITHUB_INTEGRATION=true
FEATURE_SBOM_ATTACHMENT=true
FEATURE_AUTO_INCIDENT=true
FEATURE_COMPLIANCE_EVIDENCE=true

# ----- Compliance / Audit -----
AUDIT_LOG_RETENTION_DAYS=365
EVIDENCE_BUCKET=command-center-evidence
EVIDENCE_SIGNING_KEY=
