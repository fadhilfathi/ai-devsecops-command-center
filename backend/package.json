{
  "name": "@aicc/backend",
  "version": "0.1.0",
  "private": true,
  "description": "AI-DevSecOps Command Center - Backend monorepo (6 Fastify/TypeScript services)",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm-run-all --parallel dev:*",
    "dev:auth": "npm run dev -w @aicc/auth-service",
    "dev:agent": "npm run dev -w @aicc/agent-service",
    "dev:security": "npm run dev -w @aicc/security-service",
    "dev:incident": "npm run dev -w @aicc/incident-service",
    "dev:compliance": "npm run dev -w @aicc/compliance-service",
    "dev:integration": "npm run dev -w @aicc/integration-service",
    "lint": "eslint \"{packages,services}/**/src/**/*.ts\"",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc -b",
    "clean": "rm -rf packages/*/dist services/*/dist node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
