NODE_ENV=development
SERVICE_NAME=auth-service
SERVICE_VERSION=0.1.0
HOST=0.0.0.0
PORT=4001
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ISSUER=aicc
JWT_AUDIENCE=aicc-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Database
DATABASE_URL=postgres://aicc:aicc@localhost:5432/aicc_auth

# Event bus
EVENT_BUS_DRIVER=memory
# EVENT_BUS_NATS_URL=nats://localhost:4222
