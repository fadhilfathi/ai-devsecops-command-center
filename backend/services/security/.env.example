NODE_ENV=development
SERVICE_NAME=security-service
SERVICE_VERSION=0.2.0
HOST=0.0.0.0
PORT=4003
LOG_LEVEL=info

# --- Downstream Python services (Sprint 2) ---
SBOM_PIPELINE_URL=http://localhost:4007
VULN_INTEL_URL=http://localhost:4008
DEPENDENCY_INTEL_URL=http://localhost:4009

# --- Auth (Sprint 1 stub; Sprint 2.1 will swap to RS256/JWKS via @aicc/auth) ---
JWT_ALG=HS256
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ISSUER=aicc
JWT_AUDIENCE=aicc-api

# --- Database (Sprint 2.1) ---
DATABASE_URL=postgres://aicc:aicc@localhost:5432/aicc_security

# --- Rate limiting (per-route default) ---
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=1000

# --- Event bus ---
EVENT_BUS_DRIVER=memory

# --- Observability (S2.7 — security-service :4003 prom-client metrics) ---
# Master switch for prom-client metric registration & instrumentation.
METRICS_ENABLED=true
# OTel service name. The @aicc/observability helper reads OTEL_SERVICE_NAME
# and uses it to auto-inject the `service` label on every metric
# (per metrics-spec.md §5.1.1). Override in production to match the
# fleet-wide registration (e.g. 'security-service-prod').
OTEL_SERVICE_NAME=security-service
# Expose /metrics endpoint. Disable in tests that don't need it.
METRICS_EXPOSE_ENDPOINT=true
# Note: NO METRICS_TENANT_SALT — tenant_id is forbidden on metrics
# (metrics-spec.md §5.1). Use logs (which require tenant_id) for
# per-tenant forensics, not metrics.
