NODE_ENV=development
SERVICE_NAME=security-service
SERVICE_VERSION=0.2.0
HOST=0.0.0.0
PORT=4003
LOG_LEVEL=info

# --- Downstream Python services (Sprint 2) ---
SBOM_PIPELINE_URL=http://localhost:4007
VULN_INTEL_URL=http://localhost:4008
DEPENDENCY_INTEL_URL=http://localhost:4009

# --- Auth (Sprint 1 stub; Sprint 2.1 will swap to RS256/JWKS via @aicc/auth) ---
JWT_ALG=HS256
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ISSUER=aicc
JWT_AUDIENCE=aicc-api

# --- Database (Sprint 2.1) ---
DATABASE_URL=postgres://aicc:aicc@localhost:5432/aicc_security

# --- Rate limiting (per-route default) ---
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=1000

EVENT_BUS_DRIVER=memory
