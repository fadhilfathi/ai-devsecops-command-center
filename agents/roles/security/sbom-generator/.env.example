# Local development overrides — copy to `.env` to use.
# All values match the defaults; tweak as needed.

PORT=4007
HOST=127.0.0.1
LOG_LEVEL=INFO

# Set to a real NATS URL in dev/staging/prod. `memory://` disables the
# bus entirely and is what the test suite uses.
BUS_URL=memory://

# Where Syft's workspace will live. On macOS the default
# `/var/lib/...` is not writable — override for local dev.
SBOM_WORKSPACE=/tmp/sbom-workspace

# Path to the Syft binary. Defaults to `syft` on $PATH.
# SYFT_BINARY=/usr/local/bin/syft

# Concurrency cap. Bump with care — each slot is a Syft subprocess.
MAX_CONCURRENT_SCANS=4

# Per-request timeout. Generous default to accommodate large images.
REQUEST_TIMEOUT_SECONDS=600

# When true, requires Authorization: Bearer … and X-Tenant-Id.
REQUIRE_AUTH=false
