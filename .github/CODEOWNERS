/backend/services/integration/          @aionrs/integrations
/backend/shared/                        @aionrs/backend

# Frontend
/frontend/                              @aionrs/frontend

# Infrastructure & deployment
/infra/                                 @aionrs/sre
/.github/workflows/                     @aionrs/sre
/docker-compose.yml                     @aionrs/sre
